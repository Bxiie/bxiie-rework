# Local environment files.
.env
.env.*
!.env.example

# SQLite databases.
database/*.sqlite
database/*.sqlite-*
database/*.db
database/*.db-*

# Runtime upload/cache storage.
storage/uploads/*
storage/cache/*
storage/private/*

# Keep storage directories.
!storage/uploads/.gitkeep
!storage/cache/.gitkeep
!storage/private/.gitkeep

# macOS junk.
.DS_Store

# IDE/editor junk.
.idea/
.vscode/
*.swp
*.swo

# Logs.
*.log

# End of file.
