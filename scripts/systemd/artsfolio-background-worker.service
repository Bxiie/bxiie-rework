[Unit]
Description=ArtsFolio background job worker
After=network.target mariadb.service
Wants=mariadb.service

[Service]
Type=simple
WorkingDirectory=/var/www/artsfolio
Environment=ARTSFOLIO_ENV_FILE=/etc/artsfolio/artsfolio.env
ExecStart=/usr/bin/php /var/www/artsfolio/scripts/workers/run_forever.php
Restart=always
RestartSec=5
User=www-data
Group=www-data

[Install]
WantedBy=multi-user.target

# End of file.
