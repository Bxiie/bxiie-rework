+/*
+ * ArtsFolio branded browser-facing error pages.
+ */
+:root {
+  --ink: #151515;
+  --paper: #f6efe5;
+  --muted: #665f56;
+  --line: rgba(0, 0, 0, .12);
+  --card: rgba(255, 255, 255, .82);
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  min-height: 100vh;
+  display: grid;
+  place-items: center;
+  background:
+    radial-gradient(circle at top left, rgba(255, 255, 255, .95), transparent 28rem),
+    linear-gradient(135deg, #f8f1e8, #eadfce);
+  color: var(--ink);
+  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+}
+
+.error-page {
+  width: min(860px, calc(100% - 2rem));
+}
+
+.error-card {
+  padding: clamp(2rem, 6vw, 4rem);
+  border: 1px solid var(--line);
+  border-radius: 2rem;
+  background: var(--card);
+  box-shadow: 0 28px 90px rgba(0, 0, 0, .10);
+  text-align: center;
+}
+
+.error-logo {
+  width: min(220px, 60vw);
+  height: auto;
+  margin: 0 auto 1rem;
+  display: block;
+}
+
+.error-logo-link {
+  display: inline-block;
+}
+
+.error-brand {
+  margin: 0 0 1rem;
+  font-size: 1rem;
+  font-weight: 950;
+  letter-spacing: .04em;
+}
+
+.error-eyebrow {
+  margin: 0 0 .8rem;
+  font-size: .82rem;
+  font-weight: 950;
+  letter-spacing: .16em;
+  text-transform: uppercase;
+  color: var(--muted);
+}
+
+h1 {
+  margin: 0;
+  font-size: clamp(2.7rem, 9vw, 6.5rem);
+  line-height: .9;
+  letter-spacing: -.07em;
+}
+
+.error-message {
+  margin: 1.2rem auto 0;
+  max-width: 620px;
+  color: var(--muted);
+  font-size: clamp(1.1rem, 2vw, 1.35rem);
+  line-height: 1.45;
+}
+
+.error-actions {
+  display: flex;
+  justify-content: center;
+  flex-wrap: wrap;
+  gap: .85rem;
+  margin-top: 1.6rem;
+}
+
+.error-button {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  min-height: 44px;
+  padding: .8rem 1.1rem;
+  border: 1px solid var(--ink);
+  border-radius: 999px;
+  color: inherit;
+  text-decoration: none;
+  font-weight: 950;
+}
+
+.error-button:first-child {
+  background: var(--ink);
+  color: white;
+}
+
+.error-footer {
+  margin: 1.5rem 0 0;
+  color: var(--muted);
+  font-size: .9rem;
